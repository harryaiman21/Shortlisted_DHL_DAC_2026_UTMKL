PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nexus?retryWrites=true&w=majority

JWT_SECRET=replace_with_long_random_string_min_32_chars
JWT_EXPIRES_IN=72h
COOKIE_NAME=nexus_token

RPA_API_KEY=replace_with_32_char_hex_string
ANTHROPIC_API_KEY=sk-ant-...
FASTAPI_URL=http://localhost:8000

SMTP_USER=nexus.incidents@outlook.com
SMTP_PASS=replace_with_outlook_password
