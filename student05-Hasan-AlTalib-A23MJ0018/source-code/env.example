# ── Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nexus?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_string_min_32_chars
JWT_EXPIRES_IN=72h
COOKIE_NAME=nexus_token

# ── RPA ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RPA_API_KEY=5ee1519fc8c9ac65675333cbbcaca9597497274fd427b9bb41b9a40bf7881837

# ── Anthropic ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── FastAPI ML service ────────────────────────────────────────────────
FASTAPI_URL=http://localhost:8000

# ── File uploads ─────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
