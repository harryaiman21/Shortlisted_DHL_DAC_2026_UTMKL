generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  EDITOR
  REVIEWER
  ADMIN
  RPA_BOT
}

enum ArticleStatus {
  DRAFT
  REVIEWED
  PUBLISHED
  ARCHIVED
}

enum SourceType {
  TEXT
  PDF
  DOCX
  IMAGE
  EMAIL
  CHAT
  OTHER
}

enum AutomationStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL_SUCCESS
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdArticles   Article[] @relation("ArticleCreator")
  reviewedArticles  Article[] @relation("ArticleReviewer")
  publishedArticles Article[] @relation("ArticlePublisher")
  articleVersions   ArticleVersion[]
  statusHistories   ArticleStatusHistory[]
  automationRuns    AutomationRun[]

  @@map("users")
}

model Article {
  id          Int           @id @default(autoincrement())
  title       String
  summary     String
  content     String
  sourceText  String?
  sourceType  SourceType    @default(TEXT)
  status      ArticleStatus @default(DRAFT)

  sourceHash  String?       @unique
  isDuplicate Boolean       @default(false)

  createdById   Int
  reviewedById  Int?
  publishedById Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reviewedAt  DateTime?
  publishedAt DateTime?

  createdBy   User  @relation("ArticleCreator", fields: [createdById], references: [id])
  reviewedBy  User? @relation("ArticleReviewer", fields: [reviewedById], references: [id])
  publishedBy User? @relation("ArticlePublisher", fields: [publishedById], references: [id])

  attachments     Attachment[]
  versions        ArticleVersion[]
  statusHistories ArticleStatusHistory[]
  articleTags     ArticleTag[]

  @@map("articles")
}

model ArticleVersion {
  id        Int      @id @default(autoincrement())
  articleId Int
  versionNo Int
  title     String
  summary   String
  content   String
  status    ArticleStatus

  changedById Int
  changeNote  String?

  createdAt DateTime @default(now())

  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedById], references: [id])

  @@unique([articleId, versionNo])
  @@map("article_versions")
}

model ArticleStatusHistory {
  id        Int           @id @default(autoincrement())
  articleId Int
  fromStatus ArticleStatus?
  toStatus   ArticleStatus
  note      String?

  changedById Int
  changedAt   DateTime @default(now())

  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedById], references: [id])

  @@map("article_status_histories")
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  articleTags ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  articleId Int
  tagId     Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model Attachment {
  id        Int      @id @default(autoincrement())
  articleId Int

  fileName String
  fileType String
  filePath String
  fileSize Int?

  uploadedAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model AutomationRun {
  id        Int              @id @default(autoincrement())
  runById   Int?
  status    AutomationStatus @default(RUNNING)

  totalScanned    Int @default(0)
  totalCreated    Int @default(0)
  totalUpdated    Int @default(0)
  totalDuplicates Int @default(0)
  totalFailed     Int @default(0)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  summaryEmailSent Boolean @default(false)

  runBy User? @relation(fields: [runById], references: [id])
  logs  AutomationLog[]

  @@map("automation_runs")
}

model AutomationLog {
  id              Int      @id @default(autoincrement())
  automationRunId Int
  level           LogLevel @default(INFO)
  message         String
  fileName        String?
  screenshotPath  String?
  createdAt       DateTime @default(now())

  automationRun AutomationRun @relation(fields: [automationRunId], references: [id], onDelete: Cascade)

  @@map("automation_logs")
}