# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Environment variables (contains secrets) ──────────────────────────────────
backend/.env
frontend/.env

# ── Database (auto-generated, seeded locally) ─────────────────────────────────
backend/database/*.db
backend/database/*.db-shm
backend/database/*.db-wal

# ── Uploaded files ────────────────────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Frontend build output ─────────────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
logs/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tsbuildinfo
