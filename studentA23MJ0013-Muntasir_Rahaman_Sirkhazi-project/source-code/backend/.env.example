# Copy to backend/.env and fill in real values. Never commit backend/.env.

NODE_ENV=development
PORT=3000

# Comma-separate multiple origins if needed (e.g. localhost + deployed frontend).
FRONTEND_ORIGIN=http://localhost:5500

# Supabase
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-jwt-here
# Service role key bypasses RLS — backend ONLY, never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here

# Gemini (Google AI Studio). Used by /ai/generate to keep the key off the frontend.
GEMINI_API_KEY=

# Shared secret used to authenticate UiPath -> /webhooks/uipath/* calls.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
UIPATH_WEBHOOK_SECRET=
